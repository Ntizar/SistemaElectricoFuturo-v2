# Sistema Eléctrico Futuro v2 — Variables de Entorno
#
# Copiar a .env para desarrollo local.
# Open-Meteo no requiere API key — es gratuito y sin autenticación.

# Puerto del servidor backend (solo si usas modo servidor Express)
PORT=4000

# Puerto del servidor de desarrollo Vite (frontend)
VITE_DEV_PORT=3000