{
  "name": "sistema-electrico-futuro-v2",
  "version": "2.0.0",
  "description": "Simulador interactivo del sistema eléctrico español 2026-2050 — datos reales, merit-order SRMC, Monte Carlo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "server": "tsx src/server/index.ts",
    "server:prod": "node dist-server/index.js",
    "start": "node dist-server/index.js",
    "server:dev": "tsx watch src/server/index.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "plotly.js-dist-min": "^2.35.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
